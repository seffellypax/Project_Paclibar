<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="rootPane" stylesheets="@login.css" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.project_paclibar.controller.LoginController">

    <VBox>
        <Pane fx:id="gradientHeader" prefHeight="350.0" VBox.vgrow="ALWAYS" styleClass="header-gradient">
            <children>
                <Circle centerX="50.0" centerY="50.0" radius="40.0" styleClass="bg-circle" opacity="0.3" />
                <Circle centerX="300.0" centerY="100.0" radius="60.0" styleClass="bg-circle" opacity="0.2" />
                <Circle centerX="150.0" centerY="250.0" radius="80.0" styleClass="bg-circle" opacity="0.15" />
            </children>
        </Pane>
        <Pane prefHeight="200.0" VBox.vgrow="NEVER" style="-fx-background-color: white;" />
    </VBox>

    <VBox fx:id="loginCard" alignment="TOP_CENTER" maxWidth="400.0" maxHeight="450.0" styleClass="login-card">
        <StackPane.margin>
            <Insets top="250.0" /> </StackPane.margin>
        <padding>
            <Insets top="40.0" right="30.0" bottom="30.0" left="30.0" />
        </padding>

        <children>
            <Label text="Hello!" styleClass="card-title" />
            <Label text="Sign in to your E-Wallet" styleClass="card-subtitle" />

            <VBox spacing="5.0">
                <Label text="Email" styleClass="field-label" />
                <TextField fx:id="emailField" promptText="your.email@example.com" styleClass="modern-field" />
                <VBox.margin>
                    <Insets top="30.0" />
                </VBox.margin>
            </VBox>

            <VBox spacing="5.0">
                <Label text="Password" styleClass="field-label" />
                <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="modern-field" />
                <VBox.margin>
                    <Insets top="15.0" />
                </VBox.margin>
            </VBox>

            <Hyperlink text="Forgot Password?" styleClass="forgot-link">
                <VBox.margin>
                    <Insets top="10.0" />
                </VBox.margin>
            </Hyperlink>

            <Button text="SIGN IN" onAction="#handleLogin" styleClass="gradient-button" maxWidth="Infinity">
                <VBox.margin>
                    <Insets top="25.0" />
                </VBox.margin>
            </Button>

            <HBox alignment="CENTER" spacing="5.0">
                <VBox.margin>
                    <Insets top="20.0" />
                </VBox.margin>
                <Label text="Don't have account?" styleClass="signup-prompt" />
                <Hyperlink text="Sign up" styleClass="signup-link" />
            </HBox>
        </children>
    </VBox>

    <Label fx:id="errorLabel" textFill="WHITE" StackPane.alignment="BOTTOM_CENTER">
        <StackPane.margin>
            <Insets bottom="20.0" />
        </StackPane.margin>
    </Label>

</StackPane>