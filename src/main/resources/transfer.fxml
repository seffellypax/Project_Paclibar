<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="TOP_CENTER" spacing="25.0" style="-fx-background-color: #f8f9fa;"
      stylesheets="@login.css" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.project_paclibar.controller.TransferController">

    <padding>
        <Insets top="40" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT">
        <Button text="&lt;" onAction="#handleBack" style="-fx-background-color: transparent; -fx-font-size: 20px;"/>
        <Label text="Send Money" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-padding: 0 0 0 20;"/>
    </HBox>

    <Label fx:id="balanceDisplayLabel" text="Available Balance: PHP 0.00"
           style="-fx-font-size: 14px; -fx-text-fill: #b71c44; -fx-font-weight: bold;"/>

    <VBox alignment="CENTER" spacing="10" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
        <Label text="How much would you like to send?" style="-fx-text-fill: #777;"/>
        <TextField fx:id="amountField" promptText="0.00" alignment="CENTER" style="-fx-font-size: 24px; -fx-background-color: transparent;"/>
        <Label text="PHP" style="-fx-text-fill: #b71c44; -fx-font-weight: bold;"/>
    </VBox>

    <VBox spacing="10">
        <Label text="Choose a Recipient" style="-fx-font-weight: bold;"/>
        <TextField fx:id="recipientField" promptText="Enter Name or Account Number" styleClass="modern-field"/>
    </VBox>

    <Label fx:id="statusLabel" />

    <Button text="Send Money" onAction="#handleTransfer" maxWidth="Infinity" styleClass="gradient-button"/>

</VBox>